rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default deny (C6) ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ─────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // B6/A1: admin = JWT Custom Claim OR isAdminAccount flag in the user document.
    // We check the stored document (resource.data) for the Firestore-side check,
    // so the request token alone can still grant admin via the JWT path.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdminAccount == true)
      );
    }

    // ── Users ───────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();

      // H4/A1: Closed field list for user creation.
      // isAdminAccount cannot be set by participants on create — only by admins.
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['role', 'overallRank', 'isAdminAccount'])
        && request.resource.data.isActive == true
        && request.resource.data.keys().hasOnly([
             'uid', 'id', 'name', 'email', 'studentId',
             'gitHubId', 'leetCodeId',
             'gitHubStreak', 'leetCodeStreak',
             'totalCodingScore', 'totalDebuggingScore',
             'isActive', 'completedDays', 'createdAt',
             // F1: HackerRank contest fields (optional at registration, set later by coordinator)
             'hackerRankId'
           ]);

      // B6/C2: Self-update: cannot touch privileged fields.
      // isAdminAccount is now explicitly blocked from self-modification.
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['totalCodingScore', 'totalDebuggingScore', 'overallRank', 'isAdminAccount', 'isActive', 'gitHubStreak', 'leetCodeStreak']);

      // C2: Admins can update anything.
      allow update, delete: if isAdmin();
    }

    // ── Submissions ─────────────────────────────────────────────────────
    match /submissions/{subId} {
      // H3: Users can read their own submissions, admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());

      // H3/C4: Users can create/update only their own submissions.
      // Prevent tampering with graded fields (marks, gradedBy, gradedAt).
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId
        && !request.resource.data.keys().hasAny(['marks', 'gradedBy', 'gradedAt']);

      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.userId
        && request.auth.uid == request.resource.data.userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['marks', 'gradedBy', 'gradedAt']);

      // C4: Admins have full access.
      allow update, delete: if isAdmin();
    }

    // ── Sunday Debugging (H1/A2) ────────────────────────────────────────
    match /debuggingChallenges/{challengeId} {
      // F4: All authenticated users can view challenges.
      allow read: if isAuthenticated();
      // B3: Only admins can manage challenges (creation, editing)
      allow write: if isAdmin();
    }

    match /debuggingSubmissions/{subId} {
      // Users can see their own debugging submissions; admins can see all.
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());

      // F5/C4: Users submit their own work, without assigning grades.
      allow create: if isAuthenticated()
        && request.auth.uid == request.resource.data.userId
        && !request.resource.data.keys().hasAny(['score', 'gradedAt']);

      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.userId
        && request.auth.uid == request.resource.data.userId
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['score', 'gradedAt']);

      // C4: Admins can grade and manage all submissions.
      allow update, delete: if isAdmin();
    }

    // ── Questions Cache (B5/D2) ─────────────────────────────────────────
    match /questions/{questionId} {
      // D2: Anyone authenticated can read
      allow read: if isAuthenticated();
      // B5: Admin-only modification
      allow write: if isAdmin();
    }

    // ── Global System Configuration ─────────────────────────────────────
    match /system/{docId} {
      // H5: Ensure time travel (currentDay) and constants are readable by all.
      allow read: if isAuthenticated();
      // B3: Only Admins can manipulate the system clock or configurations.
      allow write: if isAdmin();
    }
    
    // ── Static Assets (F2) ──────────────────────────────────────────────
    // Note: This applies to Firestore documents representing asset metadata, if any.
    // If you are using Firebase Storage, you need storage.rules, not firestore.rules.
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
