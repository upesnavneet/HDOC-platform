rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default deny (C6) ──────────────────────────────────────────────
    // Everything not explicitly permitted below is forbidden.
    // This rule is the base layer — more specific rules override it.
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ─────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin identity verified via Custom Claims set by Firebase Admin SDK (C3).
    // This does NOT read from Firestore — the signal comes from the signed JWT.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // ── Users ───────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();

      // Create own document only.
      // Cannot set privileged fields: role, overallRank (C2 + C5).
      // isActive must be true for new accounts.
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['role', 'overallRank'])
        && request.resource.data.isActive == true;

      // Update own document: cannot touch role, isActive, or overallRank (C2).
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'isActive', 'overallRank']);

      // Admin: full write access via Custom Claims.
      allow update, delete: if isAdmin();
    }

    // ── Questions ───────────────────────────────────────────────────────
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Submissions ─────────────────────────────────────────────────────
    match /submissions/{subId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      // Update: verify ownership on the EXISTING document (resource.data),
      // not the incoming data, to prevent userId spoofing.
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── Debugging Challenges ────────────────────────────────────────────
    match /debuggingChallenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Debugging Submissions ───────────────────────────────────────────
    match /debuggingSubmissions/{subId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ── System Config ───────────────────────────────────────────────────
    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
