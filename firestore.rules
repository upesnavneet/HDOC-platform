rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default deny (C6) ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ── Helpers ─────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    // B6/A1: admin = JWT Custom Claim OR isAdminAccount flag in the user document.
    // We check the stored document (resource.data) for the Firestore-side check,
    // so the request token alone can still grant admin via the JWT path.
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdminAccount == true)
      );
    }

    // ── Users ───────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthenticated();

      // H4/A1: Closed field list for user creation.
      // isAdminAccount cannot be set by participants on create — only by admins.
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(['role', 'overallRank', 'isAdminAccount'])
        && request.resource.data.isActive == true
        && request.resource.data.keys().hasOnly([
             'uid', 'id', 'name', 'email', 'studentId',
             'gitHubId', 'leetCodeId',
             'gitHubStreak', 'leetCodeStreak',
             'totalCodingScore', 'totalDebuggingScore',
             'isActive', 'completedDays', 'createdAt',
             // F1: HackerRank contest fields (optional at registration, set later by coordinator)
             'hackerRankId'
           ]);

      // B6/C2: Self-update: cannot touch privileged fields.
      // isAdminAccount is now explicitly blocked from self-modification.
      allow update: if isAuthenticated()
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'isActive', 'overallRank', 'isAdminAccount',
                       'totalCodingScore', 'totalDebuggingScore',
                       'contestScore', 'contestsPlayed', 'bestContestRank']);

      // Admin: full write access via Custom Claims.
      allow update, delete: if isAdmin();
    }

    // ── Questions ───────────────────────────────────────────────────────
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Submissions ─────────────────────────────────────────────────────
    match /submissions/{subId} {
      allow read: if isAuthenticated();

      // H4: Validate submission schema on create.
      // Users cannot set marks, gradedBy, comments, gradedAt, or status — those are admin fields.
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
             'id', 'userId', 'questionId', 'day', 'type',
             'code', 'language', 'timestamp', 'status',
             'marks', 'gradedBy', 'comments', 'gradedAt', 'link'
           ])
        && request.resource.data.day is int
        && request.resource.data.type is string
        && get(/databases/$(database)/documents/system/config).data.currentDay % 7 != 0
        && request.resource.data.day == get(/databases/$(database)/documents/system/config).data.currentDay;

      // Self-update: can update own submission but NOT marks/gradedBy/comments/gradedAt.
      // And can only update submissions for the current active day!
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && get(/databases/$(database)/documents/system/config).data.currentDay % 7 != 0
        && resource.data.day == get(/databases/$(database)/documents/system/config).data.currentDay
        && request.resource.data.day == resource.data.day
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['marks', 'gradedBy', 'comments', 'gradedAt']);

      // Admin: full write access.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Debugging Challenges ────────────────────────────────────────────
    match /debuggingChallenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Debugging Submissions ───────────────────────────────────────────
    match /debuggingSubmissions/{subId} {
      allow read: if isAuthenticated();

      // H4: Validate debugging submission schema.
      // Users cannot set score — that is graded by admin.
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasOnly([
             'id', 'challengeId', 'userId', 'link', 'timestamp', 'score'
           ])
        && request.resource.data.score == null;

      // Self-update: cannot change score.
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['score']);

      // Admin: full write access.
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── System Config ───────────────────────────────────────────────────
    match /system/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
